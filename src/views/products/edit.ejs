<%- include('../partials/header') %>

    <main class="form-page">

        <div class="form-container">

            <h1>Edit Product</h1>

            <form action="/products/edit/<%= product.id %>" method="POST">

                <div class="form-group">
                    <label>Name</label>
                    <input type="text" name="name" value="<%= product.name %>" required>
                </div>

                <div class="form-group">
                    <label>Price (€)</label>
                    <input type="number" step="0.01" name="price" value="<%= product.price %>" required>
                </div>

                <div class="form-group">
                    <label>Collection</label>
                    <input type="text" name="collection" value="<%= product.collection %>">
                </div>

                <div class="form-group">
                    <label>Gender</label>
                    <input type="text" name="gender" value="<%= product.gender %>">
                </div>

                <div class="form-group">
                    <label>Size</label>
                    <input type="text" name="size" value="<%= product.size %>">
                </div>

                <div class="form-group">
                    <label>Image</label>

                    <div class="image-preview-container">
                        <img id="imagePreview"
                            src="<%= product.imageUrl || 'https://placehold.co/600x800?text=No+Image' %>">
                    </div>

                    <input type="url" id="imageUrl" name="imageUrl" value="<%= product.imageUrl %>" required>
                </div>

                <div class="form-group">
                    <label>Stock</label>
                    <input type="number" name="stock" value="<%= product.stock %>">
                </div>

                <div class="form-group">
                    <label>Discount (%)</label>
                    <input type="number" name="discount" value="<%= product.discount %>">
                </div>

                <button class="btn-primary">
                    Save Changes
                </button>

            </form>

        </div>

    </main>

    <%- include('../partials/footer') %>