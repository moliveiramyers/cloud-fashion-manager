<%- include('../partials/header') %>

<main class="form-page">

    <div class="form-container">

        <h1>Add Collection</h1>

        <form
            action="/products/collections/create"
            method="POST"
        >

            <div class="form-group">
                <label>Name</label>

                <input
                    type="text"
                    name="name"
                    required
                >
            </div>

            <div class="form-group">
                <label>Description</label>

                <textarea
                    name="description"
                    rows="4"
                ></textarea>
            </div>

            <button
                type="submit"
                class="btn-primary"
            >
                Create Collection
            </button>

        </form>

    </div>

</main>

<%- include('../partials/footer') %>